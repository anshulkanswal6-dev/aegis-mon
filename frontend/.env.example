# AEGIS Frontend Environment Configuration

# --- API & Backend ---
# The URL of your deployed backend
VITE_API_URL=https://your-backend-api.onrender.com

# --- Supabase (Public Client) ---
VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# --- Web3 Settings ---
VITE_NETWORK_NAME="Monad Testnet"
VITE_CURRENCY_SYMBOL=MON
VITE_CHAIN_ID=10143
VITE_RPC_URL=https://testnet-rpc.monad.xyz
VITE_EXPLORER_URL=https://testnet.monadexplorer.com

# --- Contract Addresses ---
VITE_AGENT_WALLET_FACTORY_ADDRESS=YOUR_FACTORY_CONTRACT_ADDRESS
VITE_PLATFORM_EXECUTOR_ADDRESS=YOUR_PLATFORM_EXECUTOR_ADDRESS

# --- WalletConnect ---
VITE_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# --- Site Identity ---
VITE_SITE_NAME=AEGIS
VITE_TAGLINE="On-chain Agentic Automations"
VITE_APP_URL=https://your-frontend-domain.com
