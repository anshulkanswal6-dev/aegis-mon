# AEGIS Backend Environment Configuration

# --- Operational Settings ---
DEFAULT_PLANNING_MODEL=gemini_flash
DEFAULT_CODEGEN_MODEL=gemini_flash

# --- LLM API Keys ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- Web3 / Blockchain ---
# Private key for the platform executor (must have MON or native gas tokens)
EXECUTOR_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
EXECUTOR_ADDRESS=YOUR_PUBLIC_ADDRESS_HERE

# Monad Testnet / Network Settings
RPC_URL=https://testnet-rpc.monad.xyz
EXPLORER_URL=https://testnet.monadexplorer.com
CHAIN_ID=10143
CHAIN_NAME="Monad Testnet"
CURRENCY_SYMBOL=MON
AGENT_WALLET_FACTORY_ADDRESS=YOUR_FACTORY_CONTRACT_ADDRESS_HERE

# --- Supabase Configuration ---
STORE_BACKEND=supabase
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Integrations ---
# Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_BOT_USERNAME=YOUR_BOT_USERNAME
TELEGRAM_WEBHOOK_URL=https://your-backend-url.com/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=A_RANDOM_SECURE_STRING

# Email (Resend)
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=your-verified-email@domain.com

# --- Security ---
# Comma-separated list of allowed frontend origins for CORS
CLIENT_ORIGIN=https://your-frontend-domain.com,http://localhost:5173
