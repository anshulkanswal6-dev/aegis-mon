{
  "version": "1.0.0",
  "meta": {
    "name": "Onchain Automation Trigger Catalogue",
    "description": "Source of truth for triggers, required fields, validation hints, and Python handler mapping."
  },
  "global_required_fields": [
    "chain",
    "rpc_url",
    "wallet_address"
  ],
  "field_definitions": {
    "chain": {
      "type": "string",
      "question": "Which chain should I use for this automation?"
    },
    "rpc_url": {
      "type": "url",
      "question": "Please provide the RPC URL for that chain."
    },
    "wallet_address": {
      "type": "evm_address",
      "question": "Which Agent Wallet address should execute this automation?"
    },
    "timezone": {
      "type": "string",
      "question": "What timezone should I use?"
    },
    "date": {
      "type": "date",
      "question": "What date should I use?"
    },
    "time": {
      "type": "time",
      "question": "What time should I use?"
    },
    "interval": {
      "type": "interval",
      "question": "What interval should I use? Example: 5m, 1h, 24h"
    },
    "cron": {
      "type": "cron",
      "question": "Please provide the cron expression."
    },
    "asset": {
      "type": "string",
      "question": "Which asset/token should I track?"
    },
    "quote_currency": {
      "type": "string",
      "question": "Which quote currency should I use? Example: USD"
    },
    "threshold": {
      "type": "number_or_string",
      "question": "What threshold should trigger this automation?"
    },
    "lower_bound": {
      "type": "number_or_string",
      "question": "What lower bound should I use?"
    },
    "upper_bound": {
      "type": "number_or_string",
      "question": "What upper bound should I use?"
    },
    "percent_change": {
      "type": "number",
      "question": "What percent change should trigger this automation?"
    },
    "period": {
      "type": "string",
      "question": "What period should I use? Example: 1h, 24h"
    },
    "price_source": {
      "type": "string",
      "question": "Which price source should I use? Example: chainlink, coingecko"
    },
    "token": {
      "type": "string",
      "question": "Which token balance should I watch?"
    },
    "token_address": {
      "type": "evm_address",
      "question": "What is the token contract address?"
    },
    "recipient_address": {
      "type": "evm_address",
      "question": "What is the recipient address?"
    },
    "minimum_amount": {
      "type": "number_or_string",
      "question": "What minimum amount should I use?"
    },
    "contract_address": {
      "type": "evm_address",
      "question": "Which contract address should I monitor?"
    },
    "event_signature": {
      "type": "string",
      "question": "What event signature should I use?"
    },
    "watched_address": {
      "type": "evm_address",
      "question": "Which address should I monitor?"
    },
    "gas_threshold": {
      "type": "number",
      "question": "What gas threshold should I use?"
    },
    "health_source": {
      "type": "string",
      "question": "Which network health source should I use?"
    },
    "protocol": {
      "type": "string",
      "question": "Which protocol should I use?"
    },
    "position_reference": {
      "type": "string",
      "question": "Which position should I monitor?"
    },
    "pool": {
      "type": "string",
      "question": "Which pool should I monitor?"
    },
    "position_id": {
      "type": "string",
      "question": "What is the position ID?"
    },
    "collection": {
      "type": "string",
      "question": "Which NFT collection should I use?"
    },
    "floor_price_source": {
      "type": "string",
      "question": "Which floor price source should I use?"
    },
    "marketplace": {
      "type": "string",
      "question": "Which marketplace should I use?"
    },
    "trait_filter": {
      "type": "string",
      "question": "What NFT trait filter should I use?"
    },
    "faucet_url": {
      "type": "url",
      "question": "What is the faucet URL?"
    },
    "claim_method": {
      "type": "string",
      "question": "How does the faucet claim work? Example: http_get, http_post, wallet_sign, browser"
    },
    "api_url": {
      "type": "url",
      "question": "What API URL should I use?"
    },
    "response_field": {
      "type": "string",
      "question": "Which response field should I read from the API?"
    },
    "operator": {
      "type": "enum",
      "allowed": ["eq", "neq", "gt", "gte", "lt", "lte", "contains", "not_contains"],
      "question": "Which comparison operator should I use?"
    },
    "feed_url": {
      "type": "url",
      "question": "What feed URL should I monitor?"
    },
    "approver_reference": {
      "type": "string",
      "question": "Who should approve this action?"
    },
    "approver_references": {
      "type": "array",
      "question": "Who are the approvers?"
    },
    "duration": {
      "type": "string",
      "question": "How long should the condition remain true?"
    },
    "retry_interval": {
      "type": "interval",
      "question": "How often should retries happen?"
    },
    "timeout": {
      "type": "interval",
      "question": "What timeout should I use?"
    },
    "previous_step_reference": {
      "type": "string",
      "question": "Which previous step should this depend on?"
    },
    "to": {
      "type": "email",
      "question": "Which email should receive notifications?"
    },
    "notification_cooldown": {
      "type": "number",
      "question": "How many seconds should we wait between notifications? (Optional, default is 300s)"
    }
  },
  "triggers": [
    {
      "type": "run_once_at_datetime",
