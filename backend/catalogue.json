    },
    {
      "type": "token_price_above",
      "category": "price",
      "python_handler": "trigger_token_price_above",
      "description": "Trigger when token price goes above threshold.",
      "required_fields": ["asset", "quote_currency", "threshold", "price_source"]
    },
    {
      "type": "token_price_crosses_range",
