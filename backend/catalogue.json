      "python_handler": "trigger_run_once_at_datetime",
      "description": "Run once at a specific date and time.",
      "required_fields": ["date", "time", "timezone"]
    },
    {
      "type": "run_daily_at_time",
      "category": "time",
      "python_handler": "trigger_run_daily_at_time",
      "description": "Run every day at a fixed time.",
      "required_fields": ["time", "timezone"]
    },
    {
      "type": "run_weekly_on_day_time",
      "category": "time",
      "python_handler": "trigger_run_weekly_on_day_time",
      "description": "Run weekly on a specific day and time.",
      "required_fields": ["time", "timezone", "weekday"]
    },
    {
      "type": "run_monthly_on_date_time",
      "category": "time",
      "python_handler": "trigger_run_monthly_on_date_time",
